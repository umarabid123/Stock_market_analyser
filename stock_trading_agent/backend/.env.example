# ============================================
# AI Forex & Commodity Trading Assistant
# Backend Configuration
# ============================================

# ============= API Keys =============

# TwelveData API (primary market data provider)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# OANDA Forex API (optional fallback)
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# Alpha Vantage API (optional)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Finnhub API (optional sentiment)
FINNHUB_API_KEY=your_finnhub_api_key_here

# ============= Data Provider Selection =============

# Options: "auto" (tries TwelveData first, falls back to yfinance), "twelvedata", "oanda", "yfinance"
DATA_PROVIDER=auto

# ============= Defaults =============

# Default market: "Forex", "Commodities", or "Crypto"
DEFAULT_MARKET=Forex

# Default trading pair
DEFAULT_PAIR=EUR/USD

# Default lookback period: "1d", "5d", "1mo", "3mo", "6mo"
DEFAULT_LOOKBACK=5d

# Default timeframe: "1m", "5m", "15m", "1h", "4h", "1d"
DEFAULT_TIMEFRAME=15m

# ============= Safety Settings =============

# Paper trading mode only (no real money)
PAPER_TRADING_ONLY=true

# ============= Alerts (Optional) =============

# Telegram Bot Token for alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============= Frontend Integration =============

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============= Logging =============

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
